{
  "expo": {
    "name": "Log Planet",
    "slug": "log-to-letter",
    "scheme": "logtoletter",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#070d2a"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "1",
      "bundleIdentifier": "com.logtoletter.app",
      "infoPlist": {
        "CFBundleDisplayName": "Log Planet",
        "CFBundleName": "Log Planet",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "순간의 생각을 기록할 수 있도록 알림을 보내기 위해 사용해.",
        "NSMicrophoneUsageDescription": "음성으로 생각을 기록할 때 받아쓰기를 위해 사용해.",
        "NSSpeechRecognitionUsageDescription": "말한 내용을 기록 문장으로 바꾸기 위해 사용해.",
        "NSPhotoLibraryAddUsageDescription": "이미지를 저장하기 위해 사진 보관함 접근 권한을 사용해."
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#070d2a"
      },
      "package": "com.logtoletter.app"
    },
    "plugins": [
      "expo-dev-client",
      "expo-notifications",
      "expo-media-library",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#070d2a",
          "imageWidth": 320
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "46937731-6170-43ee-9258-3bc7a75537ee"
      }
    }
  }
}
