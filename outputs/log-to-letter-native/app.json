{
  "expo": {
    "name": "Log to Letter",
    "slug": "log-to-letter",
    "scheme": "logtoletter",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3faee"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.logtoletter.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f3faee"
      },
      "package": "com.logtoletter.app"
    },
    "plugins": [
      "expo-dev-client",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "46937731-6170-43ee-9258-3bc7a75537ee"
      }
    }
  }
}
